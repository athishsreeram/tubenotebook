cleanVideoUrl(‘https://www.youtube.com/watch?v=dQw4w9WgXcQ&t=30s&si=abc123&feature=share’),
‘https://www.youtube.com/watch?v=dQw4w9WgXcQ’
);
});

test(‘cleanVideoUrl: converts youtu.be to full URL’, () => {
assert(
cleanVideoUrl(‘https://youtu.be/dQw4w9WgXcQ?si=XYZtracking’),
‘https://www.youtube.com/watch?v=dQw4w9WgXcQ’
);
});

test(‘cleanVideoUrl: leaves already-clean URL unchanged’, () => {
assert(
cleanVideoUrl(‘https://www.youtube.com/watch?v=abc123’),
‘https://www.youtube.com/watch?v=abc123’
);
});

test(‘cleanVideoUrl: handles URL without http prefix’, () => {
assert(
cleanVideoUrl(‘www.youtube.com/watch?v=xyz999&list=PLabc’),
