// ── Inline the functions under test (mirrors tubenotebook.mjs) ───────────────

function cleanVideoUrl(url) {
try {
const u = new URL(url.startsWith(‘http’) ? url : ‘https://’ + url);
const v = u.searchParams.get(‘v’)
|| (u.hostname === ‘youtu.be’ ? u.pathname.slice(1) : null);
return v ? `https://www.youtube.com/watch?v=${v}` : url;
} catch { return url; }
}

function isSingleVideo(input) {
return input.includes(’/watch?v=’) || input.includes(‘youtu.be/’);
}

function resolveChannelUrl(input) {
if (input.startsWith(’@’)) return `https://www.youtube.com/${input}/videos`;
if (input.includes(‘youtube.com’) || input.includes(‘youtu.be’)) {
if (input.includes(’/watch?v=’) || input.includes(‘youtu.be/’)) return input;
if (input.includes(’/@’) || input.includes(’/channel/’) || input.includes(’/user/’)) {
const u = new URL(input.startsWith(‘http’) ? input : ‘https://’ + input);
return `https://www.youtube.com${u.pathname}/videos`;
}
}
return input;
}

function extractVideosFromData(data, limit) {
const videos = [];
const walk = (obj) => {
if (!obj || typeof obj !== ‘object’) return;
if (videos.length >= limit) return;
if (obj.videoId && obj.title) {
const title = obj.title?.runs?.[0]?.text || obj.title?.simpleText || ‘Untitled’;
videos.push({
id: obj.videoId,
title: title.trim(),
url: `https://www.youtube.com/watch?v=${obj.videoId}`,
meta: obj.publishedTimeText?.simpleText || ‘’,
});
return;
}
if (Array.isArray(obj)) { obj.forEach(walk); return; }
Object.values(obj).forEach(walk);
};
walk(data);
return videos.slice(0, limit);
}

// ── Test runner ───────────────────────────────────────────────────────────────
let passed = 0, failed = 0;
const failures = [];

function test(name, fn) {
try {
fn();
console.log(`  ✅  ${name}`);
passed++;
} catch (e) {
console.log(`  ❌  ${name}`);
console.log(`      ${e.message}`);
failures.push({ name, error: e.message });
failed++;
}
}

function assert(actual, expected, label = ‘’) {
if (actual !== expected)
throw new Error(`${label}\n      got:      "${actual}"\n      expected: "${expected}"`);
}

function assertContains(str, sub) {
if (!str.includes(sub)) throw new Error(`Expected string to contain: "${sub}"`);
}

function assertTruthy(val, msg) {
if (!val) throw new Error(msg || `Expected truthy, got: ${val}`);
}

