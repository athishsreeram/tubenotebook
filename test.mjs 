// ── SUITE 4: ytInitialData Parsing ────────────────────────────────────────────
console.log(’\n\x1b[1mSuite 4: ytInitialData Video Extraction\x1b[0m’);

test(‘extractVideosFromData: extracts from runs title format’, () => {
const data = {
items: [
{ videoId: ‘vid001’, title: { runs: [{ text: ‘Build an AI Agent’ }] } },
]
};
const videos = extractVideosFromData(data, 10);
assert(videos[0].id, ‘vid001’);
assert(videos[0].title, ‘Build an AI Agent’);
assert(videos[0].url, ‘https://www.youtube.com/watch?v=vid001’);
});

test(‘extractVideosFromData: extracts from simpleText title format’, () => {
const data = {
items: [{ videoId: ‘vid002’, title: { simpleText: ‘RAG vs Fine-Tuning’ } }]
};
const videos = extractVideosFromData(data, 10);
assert(videos[0].title, ‘RAG vs Fine-Tuning’);
});

test(‘extractVideosFromData: finds videos in deeply nested structure’, () => {
const data = {
contents: {
twoColumnBrowseResultsRenderer: {
tabs: [{
tabRenderer: {
content: {
richGridRenderer: {
contents: [
{ richItemRenderer: { content: {
videoRenderer: {
videoId: ‘deep001’,
title: { runs: [{ text: ‘Deep Nested Video’ }] }
}
}}},
]
}
}
}
}]
}
}
};
const videos = extractVideosFromData(data, 10);
assertTruthy(videos.some(v => v.id === ‘deep001’), ‘deep nested video not found’);
});

test(‘extractVideosFromData: respects limit’, () => {
const data = {
items: Array.from({ length: 20 }, (_, i) => ({
videoId: `v${i}`,
title: { simpleText: `Video ${i}` }
}))
};
const videos = extractVideosFromData(data, 5);
assert(videos.length, 5, ‘should limit to 5’);
});

test(‘extractVideosFromData: skips nodes without both videoId and title’, () => {
const data = {
channelId: ‘abc’,
channelName: ‘Test’,
items: [
{ videoId: ‘v1’, title: { simpleText: ‘Good’ } },
{ videoId: ‘v2’ },          // missing title
{ title: { simpleText: ‘No ID’ } },  // missing videoId
]
};
const videos = extractVideosFromData(data, 10);
assert(videos.length, 1, ‘should only find 1 valid video’);
});

test(‘extractVideosFromData: handles empty data gracefully’, () => {
const videos = extractVideosFromData({}, 10);
assert(videos.length, 0);
});

