function resolveChannelUrl(input) {
if (input.startsWith(’@’)) return `${YT_API}${input}/videos`;
if (input.includes(‘youtube.com’) || input.includes(‘youtu.be’)) {
// Single video
if (input.includes(’/watch?v=’) || input.includes(‘youtu.be/’)) return input;
// Channel URL
if (input.includes(’/@’) || input.includes(’/channel/’) || input.includes(’/user/’)) {
const u = new URL(input.startsWith(‘http’) ? input : ‘https://’ + input);
return `https://www.youtube.com${u.pathname}/videos`;
}
}
return input;
}

function isSingleVideo(input) {
return input.includes(’/watch?v=’) || input.includes(‘youtu.be/’);
}

function cleanVideoUrl(url) {
try {
const u = new URL(url.startsWith(‘http’) ? url : ‘https://’ + url);
const v = u.searchParams.get(‘v’)
|| (u.hostname === ‘youtu.be’ ? u.pathname.slice(1) : null);
return v ? `https://www.youtube.com/watch?v=${v}` : url;
} catch { return url; }
}

async function getVideoTitle(videoId) {
try {
const html = await fetchYouTubePage(`https://www.youtube.com/watch?v=${videoId}`);
const m = html.match(/<title>(.+?) - YouTube</title>/);
return m ? m[1] : ‘Unknown title’;
} catch { return ‘Unknown title’; }
}

// ── Copy to clipboard ─────────────────────────────────────────────────────────
async function copyToClipboard(text) {
const { platform } = process;
try {
const { execSync } = await import(‘child_process’);
if (platform === ‘darwin’) {
execSync(‘pbcopy’, { input: text });
return true;
} else if (platform === ‘linux’) {
execSync(‘xclip -selection clipboard’, { input: text });
return true;
} else if (platform === ‘win32’) {
execSync(‘clip’, { input: text });
return true;
}
} catch {}
return false;
}

// ── Open browser ──────────────────────────────────────────────────────────────
async function openBrowser(url) {
try {
const { execSync } = await import(‘child_process’);
const { platform } = process;
if (platform === ‘darwin’) execSync(`open "${url}"`);
else if (platform === ‘linux’) execSync(`xdg-open "${url}"`);
else if (platform === ‘win32’) execSync(`start "${url}"`);
return true;
} catch { return false; }
}

