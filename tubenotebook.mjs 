// ── CLI Arg parsing ───────────────────────────────────────────────────────────
function parseArgs(args) {
const result = { input: null, limit: 10, copy: false, open: false, help: false };
for (let i = 0; i < args.length; i++) {
if (args[i] === ‘–limit’ || args[i] === ‘-l’) result.limit = parseInt(args[++i]) || 10;
else if (args[i] === ‘–copy’ || args[i] === ‘-c’) result.copy = true;
else if (args[i] === ‘–open’ || args[i] === ‘-o’) result.open = true;
else if (args[i] === ‘–help’ || args[i] === ‘-h’) result.help = true;
else if (!args[i].startsWith(’-’)) result.input = args[i];
}
return result;
}

